# === ZORUNLU DEĞİŞKENLER (MUTLAKA DOLDUR) ===

# Telegram API bilgileri - https://my.telegram.org adresinden al
API_ID=
API_HASH=

# Bot tokeni - @BotFather'dan al
BOT_TOKEN=

# MongoDB URI - https://cloud.mongodb.com adresinden al
MONGO_DB_URI=

# Botun sahibinin Telegram ID'si (kendi ID'ni yaz!)
OWNER_ID=

# Log grubu/kanalı ID'si (botun eklenmis ve admin yapılmış olmalı)
LOGGER_ID=

# String Session (en az bir tane gerekli) - Pyrogram session string
STRING_SESSION=

# === İSTEĞE BAĞLI DEĞİŞKENLER ===

# YouTube API (BrokenXAPI kullanılıyorsa)
# YTKEY=

# Spotify bilgileri (Spotify desteği istiyorsan)
# SPOTIFY_CLIENT_ID=
# SPOTIFY_CLIENT_SECRET=

# Destek kanalı ve grubu (kendi kanalını yaz)
# SUPPORT_CHANNEL=https://t.me/KanalAdin
# SUPPORT_CHAT=https://t.me/GrupAdin

# Ek String Session'lar (birden fazla asistan için)
# STRING_SESSION2=
# STRING_SESSION3=
# STRING_SESSION4=
# STRING_SESSION5=
